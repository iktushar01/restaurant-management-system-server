model Property {
  id              String   @id @default(uuid())
  propertyName    String?
  propertyGrade   String?
  city            String?
  state           String?
  phone           String?
  email           String?
  registrationVAT String?
  registrationCST String?
  propertyType    String?
  address         String?
  postalCode      String?
  country         String?
  fax             String?
  website         String?
  registrationTIN String?
  companyLogo     String?
  vatPercent      Decimal  @default(0) @db.Decimal(5, 2)
  serviceChargePercent Decimal @default(0) @db.Decimal(5, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("properties")
}

model WorkPeriod {
  id          String           @id @default(uuid())
  startDate   DateTime
  endDate     DateTime?
  openingCash Decimal          @default(0) @db.Decimal(12, 2)
  totalSale   Decimal          @default(0) @db.Decimal(12, 2)
  discount    Decimal          @default(0) @db.Decimal(12, 2)
  cashPayment Decimal          @default(0) @db.Decimal(12, 2)
  cardPayment Decimal          @default(0) @db.Decimal(12, 2)
  totalPaid   Decimal          @default(0) @db.Decimal(12, 2)
  onTheHouse  Decimal          @default(0) @db.Decimal(12, 2)
  closingCash Decimal          @default(0) @db.Decimal(12, 2)
  status      WorkPeriodStatus @default(OPEN)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  orders      Order[]

  @@map("work_periods")
}

model FoodCategory {
  id        String    @id @default(uuid())
  name      String
  note      String?
  serialNo  Int
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  foods     Food[]

  @@map("food_categories")
}

model Food {
  id           String       @id @default(uuid())
  categoryId   String
  category     FoodCategory @relation(fields: [categoryId], references: [id])
  foodNo       String
  name         String
  serialNo     Int
  availability Availability @default(AVAILABLE)
  price        Decimal      @db.Decimal(12, 2)
  image        String?
  isDeleted    Boolean      @default(false)
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  orderItems   OrderItem[]

  @@index([categoryId])
  @@map("foods")
}

model DineLocation {
  id         String      @id @default(uuid())
  name       String
  type       String?
  positionX  Int?
  positionY  Int?
  width      Int?
  height     Int?
  isDeleted  Boolean     @default(false)
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  tables     DineTable[]

  @@map("dine_locations")
}

model DineTable {
  id         String          @id @default(uuid())
  locationId String
  location   DineLocation    @relation(fields: [locationId], references: [id])
  tableNo    String
  capacity   Int
  status     DineTableStatus @default(AVAILABLE)
  positionX  Int?
  positionY  Int?
  isDeleted  Boolean         @default(false)
  deletedAt  DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  orders     Order[]

  @@index([locationId])
  @@map("dine_tables")
}

model Waiter {
  id        String    @id @default(uuid())
  name      String
  note      String?
  userId    String?   @unique
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  orders    Order[]

  @@map("waiters")
}

model Order {
  id           String       @id @default(uuid())
  orderType    OrderType    @default(DINE_IN)
  tableId      String?
  table        DineTable?   @relation(fields: [tableId], references: [id])
  waiterId     String?
  waiter       Waiter?      @relation(fields: [waiterId], references: [id])
  workPeriodId String?
  workPeriod   WorkPeriod?  @relation(fields: [workPeriodId], references: [id])
  status       OrderStatus  @default(PENDING)
  persons      Int?
  notes        String?
  subtotal     Decimal      @default(0) @db.Decimal(12, 2)
  total        Decimal      @default(0) @db.Decimal(12, 2)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  items        OrderItem[]

  @@index([status])
  @@index([workPeriodId])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  foodId      String
  food        Food    @relation(fields: [foodId], references: [id])
  quantity    Int     @default(1)
  sideDish    String?
  sideDishQty Int?
  note        String?
  price       Decimal @db.Decimal(12, 2)

  @@index([orderId])
  @@map("order_items")
}
