model InventoryCategory {
  id            String                 @id @default(uuid())
  name          String
  details       String?
  isDeleted     Boolean                @default(false)
  deletedAt     DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  subCategories InventorySubCategory[]
  items         InventoryItem[]

  @@map("inventory_categories")
}

model InventorySubCategory {
  id         String            @id @default(uuid())
  categoryId String
  category   InventoryCategory @relation(fields: [categoryId], references: [id])
  name       String
  isDeleted  Boolean           @default(false)
  deletedAt  DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  items      InventoryItem[]

  @@index([categoryId])
  @@map("inventory_sub_categories")
}

model Brand {
  id        String          @id @default(uuid())
  name      String
  details   String?
  isDeleted Boolean         @default(false)
  deletedAt DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     InventoryItem[]

  @@map("brands")
}

model Unit {
  id        String          @id @default(uuid())
  name      String
  isDeleted Boolean         @default(false)
  deletedAt DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     InventoryItem[]

  @@map("units")
}

model Vendor {
  id             String     @id @default(uuid())
  name           String
  address        String?
  contact        String?
  openingBalance Decimal    @default(0) @db.Decimal(12, 2)
  isDeleted      Boolean    @default(false)
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  purchases      Purchase[]

  @@map("vendors")
}

model StockLocation {
  id              String          @id @default(uuid())
  name            String
  isDeleted       Boolean         @default(false)
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  stocks          Stock[]
  movementsFrom   StockMovement[] @relation("FromLocation")
  movementsTo     StockMovement[] @relation("ToLocation")

  @@map("stock_locations")
}

model InventoryItem {
  id            String               @id @default(uuid())
  categoryId    String
  category      InventoryCategory    @relation(fields: [categoryId], references: [id])
  subCategoryId String
  subCategory   InventorySubCategory @relation(fields: [subCategoryId], references: [id])
  brandId       String?
  brand         Brand?               @relation(fields: [brandId], references: [id])
  unitId        String
  unit          Unit                 @relation(fields: [unitId], references: [id])
  name          String
  reorderLevel  Decimal              @default(0) @db.Decimal(12, 2)
  isDeleted     Boolean              @default(false)
  deletedAt     DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  stocks        Stock[]
  purchaseItems PurchaseItem[]
  movements     StockMovement[]

  @@index([categoryId])
  @@index([subCategoryId])
  @@map("inventory_items")
}

model Stock {
  id         String        @id @default(uuid())
  itemId     String
  item       InventoryItem @relation(fields: [itemId], references: [id])
  locationId String
  location   StockLocation @relation(fields: [locationId], references: [id])
  quantity   Decimal       @default(0) @db.Decimal(12, 2)
  updatedAt  DateTime      @updatedAt

  @@unique([itemId, locationId])
  @@map("stocks")
}

model Purchase {
  id           String         @id @default(uuid())
  memoNo       String
  vendorId     String
  vendor       Vendor         @relation(fields: [vendorId], references: [id])
  total        Decimal        @default(0) @db.Decimal(12, 2)
  discount     Decimal        @default(0) @db.Decimal(12, 2)
  advanceAmount Decimal       @default(0) @db.Decimal(12, 2)
  due          Decimal        @default(0) @db.Decimal(12, 2)
  purchaseDate DateTime       @default(now())
  status       PurchaseStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  items        PurchaseItem[]

  @@index([vendorId])
  @@map("purchases")
}

model PurchaseItem {
  id         String        @id @default(uuid())
  purchaseId String
  purchase   Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  itemId     String
  item       InventoryItem @relation(fields: [itemId], references: [id])
  quantity   Decimal       @db.Decimal(12, 2)
  price      Decimal       @db.Decimal(12, 2)
  subTotal   Decimal       @db.Decimal(12, 2)

  @@index([purchaseId])
  @@map("purchase_items")
}

model StockMovement {
  id             String            @id @default(uuid())
  itemId         String
  item           InventoryItem     @relation(fields: [itemId], references: [id])
  fromLocationId String?
  fromLocation   StockLocation?    @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocationId   String?
  toLocation     StockLocation?    @relation("ToLocation", fields: [toLocationId], references: [id])
  quantity       Decimal           @db.Decimal(12, 2)
  type           StockMovementType
  note           String?
  createdAt      DateTime          @default(now())

  @@index([itemId])
  @@map("stock_movements")
}

model Event {
  id            String      @id @default(uuid())
  subject       String
  customerName  String
  phone         String?
  date          DateTime
  noOfPerson    Int
  advanceAmount Decimal     @default(0) @db.Decimal(12, 2)
  menu          String?
  description   String?
  status        EventStatus @default(BOOKED)
  isDeleted     Boolean     @default(false)
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("events")
}
